# API Keys Configuration Example
# Copy this file to .env and fill in your actual keys.

# ==========================================================================
# LLM API Keys
# ==========================================================================
# OpenAI API Key
OPENAI_API_KEY=openai_api_key_here

# Google API Key (for Gemini/Gemma)
GOOGLE_API_KEY=google_api_key_here

# Groq API Key (for Qwen/Llama)
GROQ_API_KEY=grok_api_key_here

# ==========================================================================
# LangSmith Configuration (Tracing & Monitoring)
# ==========================================================================
LANGCHAIN_TRACING_V2=true                                   # Enable LangChain tracing            
LANGCHAIN_API_KEY=langsmith_api_key_here                    # Set your LangSmith API key (https://docs.langchain.com/langsmith/create-account-api-key)
LANGCHAIN_PROJECT=your_project_name_here                    # Set your LangSmith project name
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com       # LangSmith EU endpoint (change if needed)