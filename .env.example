# ==========================================================================
# API Keys Configuration Example
# ==========================================================================
# Copy this file to .env and fill in your actual keys.
# WARNING: Never commit .env to version control!

# ==========================================================================
# LLM Provider Configuration
# ==========================================================================
# Choose ONE of the following options (or use LM Studio - no key needed)

# ---------------------------
# Optional: Hugging Face Hub
# ---------------------------
# Used by local embedding/model downloads, for example BAAI/bge-m3.
# This is optional for public models, but avoids anonymous Hub requests and
# can improve rate limits/cold-start reliability in hosted deployments.
# Use a fine-grained, read-only token and store the real value only in .env
# or in the deployment platform's secret manager.
HF_TOKEN=your_huggingface_read_token_here

# ---------------------------
# Option 1: OpenAI API (Direct)
# ---------------------------
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Selection (optional)
# Available models: gpt-5.X, ... (see documentation for latest)
OPENAI_MODEL_NAME=your_openai_model_here

# ---------------------------
# Option 2: Azure OpenAI (Enterprise) - v1 API (Recommended)
# ---------------------------
# Create resource at: https://portal.azure.com
# Documentation: https://learn.microsoft.com/en-us/azure/ai-foundry/openai/api-version-lifecycle
#
# The v1 API (August 2025+) benefits:
#   - No api_version parameter needed (automatic updates)
#   - Compatible with OpenAI Python SDK  
#   - Faster feature releases
#   - Uses endpoint /openai/v1/ internally

AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here

# NOTE: AZURE_OPENAI_API_VERSION is NOT needed with v1 API (the code uses /openai/v1/ endpoint)

# ---------------------------
# Option 3: LM Studio (Local - No API Key Required)
# ---------------------------
# Download from https://lmstudio.ai/
# Load your model and start the local server on port 1234
# No API key needed - works completely offline!

# ==========================================================================
# Metro de Lisboa Official API (OAuth2)
# ==========================================================================
# Required for real-time Metro wait times, frequencies, and station info.
# Register at: https://api.metrolisboa.pt/store/
# Steps:
#   1. Create account at the API Store
#   2. Create a new Application
#   3. Subscribe to "EstadoServicoML" API
#   4. Go to Applications > Your App > Production Keys
#   5. Generate keys and copy Consumer Key/Secret
#
# TLS note:
#   As of 2026-03, the runtime keeps certificate verification enabled by default.
#   If the Metro gateway presents an incomplete chain, the code now discovers
#   and caches the missing issuer certificates dynamically from the live leaf
#   certificate's AIA metadata. The variables below are only overrides.
METRO_CONSUMER_KEY=your_metro_consumer_key_here
METRO_CONSUMER_SECRET=your_metro_consumer_secret_here

# Optional Metro TLS configuration
# Use METRO_CA_BUNDLE to override the default trust path with your own PEM bundle.
# Use METRO_SSL_VERIFY=true to force the standard system trust store only.
# Use METRO_SSL_VERIFY=false only for temporary local diagnosis.
# Use METRO_SSL_ALLOW_INSECURE_FALLBACK=true only if secure validation and
# dynamic issuer-chain completion both fail, and only as a temporary measure.
# METRO_CA_BUNDLE=C:/path/to/metro_ca_bundle.pem
# METRO_SSL_VERIFY=true
# METRO_SSL_ALLOW_INSECURE_FALLBACK=false

# ==========================================================================
# LangSmith Configuration (Tracing & Monitoring)
# ==========================================================================
# Optional but recommended for debugging and monitoring agent behavior.
# Get key: https://smith.langchain.com/ (create account first)
# 
# EU users: Use https://eu.api.smith.langchain.com as endpoint
# US users: Use https://api.smith.langchain.com as endpoint (default)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=my-thesis-project
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# Optional: required if your API key is linked to multiple LangSmith workspaces
# LANGSMITH_WORKSPACE_ID=your_langsmith_workspace_id_here

# Optional: when set to "true", LISBOA calls wait_for_all_tracers() and a
# client.read_run() probe after each interactive run to confirm LangSmith
# ingestion. This is useful for debugging persistence issues but adds ~0.5–2s
# of latency per turn, so it is OFF by default.
# LANGSMITH_SYNC_FLUSH=false

# Legacy aliases remain supported in code for backward compatibility,
# but the canonical SDK variables above are recommended.

# ==========================================================================
# Web Search Configuration
# ==========================================================================
# Tavily API Key (Optimized for LLMs)
# Get key: https://tavily.com/                  [Free Tier Available]
# Required for web search tool functionality
TAVILY_API_KEY=your_tavily_api_key_here
