# ==========================================================================
# API Keys Configuration Example
# ==========================================================================
# Copy this file to .env and fill in your actual keys.
# WARNING: Never commit .env to version control!

# ==========================================================================
# LLM Provider Configuration
# ==========================================================================
# Choose ONE of the following options (or use LM Studio - no key needed)

# ---------------------------
# Option 1: OpenAI API (Direct)
# ---------------------------
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Selection (optional)
# Available models: gpt-5.2, gpt-5.1, gpt-5, gpt-5-mini, gpt-5-nano
OPENAI_MODEL_NAME=gpt-5-nano

# ---------------------------
# Option 2: Azure OpenAI (Enterprise) - v1 API (Recommended)
# ---------------------------
# Create resource at: https://portal.azure.com
# Documentation: https://learn.microsoft.com/en-us/azure/ai-foundry/openai/api-version-lifecycle
#
# The v1 API (August 2025+) benefits:
#   - No api_version parameter needed (automatic updates)
#   - Compatible with OpenAI Python SDK  
#   - Faster feature releases
#   - Uses endpoint /openai/v1/ internally

AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-nano

# NOTE: AZURE_OPENAI_API_VERSION is NOT needed with v1 API (the code uses /openai/v1/ endpoint)

# ---------------------------
# Option 3: LM Studio (Local - No API Key Required)
# ---------------------------
# Download from https://lmstudio.ai/
# Load your model and start the local server on port 1234
# No API key needed - works completely offline!

# ==========================================================================
# Metro de Lisboa Official API (OAuth2)
# ==========================================================================
# Required for real-time Metro wait times, frequencies, and station info.
# Register at: https://api.metrolisboa.pt/store/
# Steps:
#   1. Create account at the API Store
#   2. Create a new Application
#   3. Subscribe to "EstadoServicoML" API
#   4. Go to Applications > Your App > Production Keys
#   5. Generate keys and copy Consumer Key/Secret
METRO_CONSUMER_KEY=your_metro_consumer_key_here
METRO_CONSUMER_SECRET=your_metro_consumer_secret_here

# ==========================================================================
# LangSmith Configuration (Tracing & Monitoring)
# ==========================================================================
# Optional but recommended for debugging and monitoring agent behavior.
# Get key: https://smith.langchain.com/ (create account first)
# 
# EU users: Use https://eu.api.smith.langchain.com as endpoint
# US users: Use https://api.smith.langchain.com as endpoint (default)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=my-thesis-project
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# ==========================================================================
# Web Search Configuration
# ==========================================================================
# Tavily API Key (Optimized for LLMs)
# Get key: https://tavily.com/
# Required for web search tool functionality
TAVILY_API_KEY=your_tavily_api_key_here
