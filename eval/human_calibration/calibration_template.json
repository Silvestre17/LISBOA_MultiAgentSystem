{
    "calibration_metadata": {
        "description": "Human calibration template for LLM-as-a-Judge agreement measurement",
        "instructions": "For each entry, read the query, expected facts, and response. Then score each dimension 1-5 using the rubric below.",
        "rubric": {
            "factual_accuracy": {
                "1": "Completely wrong or fabricated facts",
                "2": "Mostly incorrect with some true elements",
                "3": "Mix of correct and incorrect information",
                "4": "Mostly correct with minor errors",
                "5": "Fully accurate, all facts verified"
            },
            "tool_usage": {
                "1": "No relevant tools used; completely wrong tool selection",
                "2": "Some tools used but mostly irrelevant",
                "3": "Partially correct tool selection",
                "4": "Mostly correct tools with minor gaps",
                "5": "Perfect tool selection matching expected tools"
            },
            "completeness": {
                "1": "Fails to address the query at all",
                "2": "Addresses only a small part of the query",
                "3": "Addresses the query partially",
                "4": "Covers most aspects of the query",
                "5": "Fully comprehensive response covering all aspects"
            },
            "relevance": {
                "1": "Entirely off-topic response",
                "2": "Mostly off-topic with some relevant content",
                "3": "Partially relevant to the query",
                "4": "Mostly relevant with minor digressions",
                "5": "Perfectly focused and relevant to the query"
            },
            "response_quality": {
                "1": "Incoherent, unstructured, or incomprehensible",
                "2": "Poor structure and clarity",
                "3": "Acceptable structure but could be improved",
                "4": "Well-structured and clear",
                "5": "Excellent clarity, structure, and presentation"
            }
        }
    },
